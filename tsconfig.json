{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@shared/*": ["./proxy-inspector/src/shared/*"]
    }
  },
  "include": ["notebooklm_agent/**/*.ts", "notebooklm_agent/**/*.tsx", "test_scripts/**/*.ts", "proxy-inspector/src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "proxy-inspector/node_modules", "proxy-inspector/src/main/**", "proxy-inspector/src/preload/**", "proxy-inspector/src/renderer/**"]
}
